{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "RootPath": "App_Data\\storage",
    "RequestPath": "/media",
    "VideosFolder": "videos",
    "ThumbnailsFolder": "thumbnails",
    "MaxVideoBytes": 536870912,
    "MaxThumbnailBytes": 10485760
  },
  "MediaTools": {
    "FfmpegPath": "..\\..\\tools\\ffmpeg\\current\\bin\\ffmpeg.exe",
    "FfprobePath": "..\\..\\tools\\ffmpeg\\current\\bin\\ffprobe.exe",
    "DefaultFontFile": "C:\\Windows\\Fonts\\arial.ttf",
    "ProcessTimeoutSeconds": 15
  },
  "Platforms": {
    "YouTube": {
      "Enabled": true,
      "ApiBaseUrl": "https://www.googleapis.com/upload/youtube/v3/videos",
      "AuthBaseUrl": "https://accounts.google.com/o/oauth2",
      "RequiresPublicUrlStaging": false,
      "MaxTitleLength": 100,
      "MaxDescriptionLength": 5000,
      "MaxTags": 15,
      "MaxFileSizeMb": 262144,
      "MaxDurationSeconds": 43200,
      "RecommendedAspectRatio": "16:9",
      "RecommendedResolution": "1920x1080",
      "UploadStyle": "Resumable",
      "SupportedPrivacyValues": [ "Public", "Private", "Unlisted" ],
      "UploadScope": "https://www.googleapis.com/auth/youtube.upload"
    },
    "Facebook": {
      "Enabled": true,
      "ApiBaseUrl": "https://graph.facebook.com",
      "AuthBaseUrl": "https://www.facebook.com/dialog/oauth",
      "RequiresPublicUrlStaging": false,
      "MaxDescriptionLength": 2200,
      "MaxDurationSeconds": 90,
      "RecommendedAspectRatio": "9:16",
      "RecommendedResolution": "1080x1920",
      "UploadStyle": "Resumable session",
      "SupportedPrivacyValues": [ "Public" ],
      "MaxReelDurationSeconds": 90
    },
    "Instagram": {
      "Enabled": true,
      "ApiBaseUrl": "https://graph.instagram.com",
      "AuthBaseUrl": "https://www.facebook.com/dialog/oauth",
      "RequiresPublicUrlStaging": true,
      "MaxDescriptionLength": 2200,
      "MaxFileSizeMb": 300,
      "MaxDurationSeconds": 900,
      "RecommendedAspectRatio": "9:16",
      "RecommendedResolution": "1080x1920",
      "UploadStyle": "Media container",
      "SupportedPrivacyValues": [ "Public" ],
      "MaxStoryDurationSeconds": 60
    },
    "LinkedIn": {
      "Enabled": true,
      "ApiBaseUrl": "https://api.linkedin.com/rest",
      "AuthBaseUrl": "https://www.linkedin.com/oauth/v2",
      "RequiresPublicUrlStaging": false,
      "MaxTitleLength": 200,
      "MaxDescriptionLength": 3000,
      "MaxFileSizeMb": 5120,
      "MaxDurationSeconds": 1800,
      "RecommendedAspectRatio": "16:9",
      "RecommendedResolution": "1920x1080",
      "UploadStyle": "Signed multipart upload",
      "SupportedPrivacyValues": [ "Public", "Private" ],
      "SafeFileSizeMb": 500
    },
    "Vimeo": {
      "Enabled": true,
      "ApiBaseUrl": "https://api.vimeo.com",
      "AuthBaseUrl": "https://api.vimeo.com/oauth/authorize",
      "RequiresPublicUrlStaging": false,
      "MaxTitleLength": 128,
      "MaxDescriptionLength": 5000,
      "MaxTags": 20,
      "RecommendedAspectRatio": "16:9",
      "RecommendedResolution": "1920x1080",
      "UploadStyle": "TUS resumable",
      "SupportedPrivacyValues": [ "Public", "Private", "Unlisted" ],
      "UploadApproach": "tus"
    },
    "Dailymotion": {
      "Enabled": true,
      "ApiBaseUrl": "https://partner.api.dailymotion.com",
      "AuthBaseUrl": "https://partner.api.dailymotion.com/oauth/v1",
      "RequiresPublicUrlStaging": false,
      "MaxTitleLength": 120,
      "MaxDescriptionLength": 5000,
      "MaxTags": 15,
      "MaxFileSizeMb": 4096,
      "MaxDurationSeconds": 3600,
      "RecommendedAspectRatio": "16:9",
      "RecommendedResolution": "1920x1080",
      "UploadStyle": "Upload URL + video create",
      "SupportedPrivacyValues": [ "Public", "Private" ],
      "RequireMadeForKidsSelection": true
    },
    "Threads": {
      "Enabled": true,
      "ApiBaseUrl": "https://graph.threads.net",
      "AuthBaseUrl": "https://www.facebook.com/dialog/oauth",
      "RequiresPublicUrlStaging": true,
      "MaxDescriptionLength": 500,
      "MaxFileSizeMb": 1024,
      "MaxDurationSeconds": 300,
      "RecommendedAspectRatio": "9:16",
      "RecommendedResolution": "1080x1920",
      "UploadStyle": "Media container",
      "SupportedPrivacyValues": [ "Public" ],
      "TextLimit": 500
    },
    "Tumblr": {
      "Enabled": true,
      "ApiBaseUrl": "https://api.tumblr.com/v2",
      "AuthBaseUrl": "https://www.tumblr.com/oauth2",
      "RequiresPublicUrlStaging": true,
      "MaxDescriptionLength": 4096,
      "MaxTags": 20,
      "MaxFileSizeMb": 500,
      "MaxDurationSeconds": 600,
      "RecommendedAspectRatio": "1:1",
      "RecommendedResolution": "1080x1080",
      "UploadStyle": "Multipart post create",
      "SupportedPrivacyValues": [ "Public", "Private" ],
      "MaxDailyVideos": 20
    },
    "Telegram": {
      "Enabled": true,
      "ApiBaseUrl": "https://api.telegram.org",
      "AuthBaseUrl": "Bot token",
      "RequiresPublicUrlStaging": false,
      "MaxDescriptionLength": 1024,
      "MaxFileSizeMb": 50,
      "RecommendedAspectRatio": "16:9",
      "RecommendedResolution": "854x480",
      "UploadStyle": "Direct Bot API upload",
      "SupportedPrivacyValues": [ "Public" ],
      "SupportsStreamingByDefault": true
    }
  },
  "AllowedHosts": "*"
}
